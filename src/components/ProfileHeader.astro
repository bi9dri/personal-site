---
interface Props {
  icon: string;
  name: string;
  message: string;
}

const { icon, name, message } = Astro.props as Props;
---

<div class="flex flex-col items-center text-center mb-xl py-lg">
  <img
    id="profile-avatar"
    src={icon}
    alt={name}
    class="w-36 h-36 max-[480px]:w-24 max-[480px]:h-24 m-0 mb-md"
  />
  <p class="text-text-muted text-[0.95rem] mt-xs m-0">{message}</p>
</div>

<style>
  #profile-avatar {
    border-radius: 50%;
    box-shadow: 0 0 0 3px #0F172A, 0 0 0 5px rgba(56, 189, 248, 0.25);
  }
</style>
