<!doctype html>
<html lang="ja">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content="bidriの個人サイト - ゲーム、TRPG、マーダーミステリー" />
<title>bidri.dev</title>
<link rel="icon" type="image/webp" href="/assets/icon.webp" />
<Fragment set:html={ga4Script} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700;800;900&family=Cinzel:wght@500;700;900&family=Poppins:wght@600;700;800;900&family=Righteous&family=Shippori+Mincho:wght@600;700;800&family=Zen+Kaku+Gothic+New:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap" />
<style is:global>
  :root {
    --bg: oklch(0.13 0.035 245);
    --ink-100: oklch(0.93 0.02 235);
    --ink-200: oklch(0.80 0.04 232);
    --ink-300: oklch(0.62 0.05 230);
    --line: color-mix(in oklch, white 9%, transparent);
    --accent-cyan: oklch(0.82 0.13 205);
    --accent-sky:  oklch(0.74 0.13 232);
    --accent-blue: oklch(0.66 0.16 250);
    --accent-iris: oklch(0.60 0.16 268);
    --f-jp: "Zen Kaku Gothic New", "Hiragino Sans", sans-serif;
    --f-en: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
    --f-mono: "JetBrains Mono", ui-monospace, monospace;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: auto; }
  body {
    background-color: var(--bg); color: var(--ink-100); font-family: var(--f-jp);
    -webkit-font-smoothing: antialiased; overflow-x: hidden;
    background-image: radial-gradient(circle at 1px 1px, color-mix(in oklch, white 6%, transparent) 1px, transparent 0);
    background-size: 30px 30px;
    background-attachment: fixed;
    transition: background-color 0.7s ease;
  }
  body::before {
    content: ""; position: fixed; inset: 0; z-index: -1; pointer-events: none;
    background: radial-gradient(125% 85% at 50% 45%, transparent 52%, rgba(0,0,0,.4));
  }
  a { color: inherit; text-decoration: none; }
  ::selection { background: color-mix(in oklch, var(--accent-cyan) 35%, transparent); color: #fff; }
  ::-webkit-scrollbar { width: 10px; }
  ::-webkit-scrollbar-thumb { background: color-mix(in oklch, var(--accent-sky) 35%, transparent); }

  .glass {
    background: color-mix(in oklch, white 6%, transparent);
    border: 1px solid color-mix(in oklch, white 14%, transparent);
    -webkit-backdrop-filter: blur(20px) saturate(130%);
    backdrop-filter: blur(20px) saturate(130%);
  }

  /* ---------- Nav ---------- */
  .nav { position: sticky; top: 0; z-index: 40; padding: 14px 24px; }
  .nav-inner { max-width: 980px; margin: 0 auto; display: flex; align-items: center; gap: 16px; padding: 10px 14px 10px 18px; border-radius: 999px; background: color-mix(in oklch, oklch(0.12 0.03 245) 68%, transparent); border-color: rgba(255,255,255,.12); }
  .brand { display: flex; align-items: center; gap: 10px; }
  .brand b { font-family: var(--f-en); font-weight: 700; font-size: 16px; color: #fff; letter-spacing: 0.02em; }
  .brand-ava { width: 24px; height: 24px; border-radius: 50%; object-fit: cover; display: block; border: 1px solid color-mix(in oklch, white 18%, transparent); }
  .brand .dev { font-family: var(--f-mono); font-size: 11px; color: var(--ink-300); }
  .nav-links { display: flex; gap: 2px; margin-left: auto; }
  .nav-links a { padding: 6px 12px; font-size: 13px; color: var(--ink-200); transition: color .2s; }
  .nav-links a:hover { color: #fff; }
  .nav-cta { padding: 7px 14px; font-size: 12px; font-family: var(--f-mono); letter-spacing: 0.06em; border-radius: 999px; border: 1px solid color-mix(in oklch, var(--accent-sky) 50%, transparent); color: var(--accent-sky); }

  /* ---------- Stack ---------- */
  .stack { max-width: 980px; margin: 0 auto; padding: 44px 24px 34px; display: flex; flex-direction: column; gap: 56px; }
  .sec { scroll-margin-top: 88px; }
  .site-foot { max-width: 980px; margin: 0 auto; padding: 20px 24px 72px; display: flex; justify-content: space-between; align-items: center; font-family: var(--f-mono); font-size: 11px; color: var(--ink-300); letter-spacing: 0.08em; }

  .card { position: relative; overflow: hidden; width: 100%; border-radius: 0;
    box-shadow: 0 0 0 1px rgba(255,255,255,.05), 0 30px 55px -30px rgba(0,0,0,.72); }

  /* ============ 01 SUPREMATISM · アークナイツ ============ */
  .suprem { position: relative; min-height: 440px; background: #efece4; overflow: hidden; }
  .suprem .s { position: absolute; }
  .suprem .s-red { width: 158px; height: 116px; background: #e2231a; left: 56px; top: 44px; transform: rotate(-9deg); }
  .suprem .s-yellow { width: 50px; height: 50px; background: #f2b705; left: 250px; top: 70px; transform: rotate(16deg); }
  .suprem .s-bar { width: 300px; height: 26px; background: #111; left: 40px; top: 172px; transform: rotate(20deg); }
  .suprem .s-circle { width: 70px; height: 70px; border-radius: 50%; background: #111; left: 300px; top: 150px; }
  .suprem .s-line { width: 56px; height: 56px; background: #111; left: 372px; top: 44px; }
  .suprem .s-pic { width: 700px; aspect-ratio: 1920 / 905; right: -150px; top: 84px; border: 5px solid #111; background-image: url("/assets/arknights.webp"); background-size: cover; background-position: left center; box-shadow: 10px 12px 0 rgba(17,17,17,.12); }
  .suprem .s-title { position: absolute; left: 48px; bottom: 40px; z-index: 3; }
  .suprem .s-title h3 { font-family: "Inter", sans-serif; font-weight: 900; font-size: 42px; color: #111; letter-spacing: -0.02em; }
  .suprem .s-title .jp { font-family: "Zen Kaku Gothic New"; font-weight: 900; font-size: 22px; color: #111; margin-top: 2px; }
  .suprem .s-title .en { font-family: "Zen Kaku Gothic New"; font-weight: 500; font-size: 13px; letter-spacing: 0.02em; color: #333; margin-top: 12px; max-width: 420px; line-height: 1.75; }

  /* ============ 02 SWISS · エンドフィールド ============ */
  .swiss { background: #ededea; color: #111; font-family: "Inter"; display: flex; flex-direction: column; }
  .swiss .l { padding: 30px 34px 22px; }
  .swiss .headrow { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; }
  .swiss h3 { font-weight: 900; font-size: 52px; line-height: 0.92; letter-spacing: -0.04em; }
  .swiss .jp { font-weight: 700; font-size: 20px; margin-top: 4px; }
  .swiss .lede { font-family: "Zen Kaku Gothic New"; font-weight: 500; font-size: 14px; color: #333; line-height: 1.85; margin-top: 16px; max-width: 660px; }
  .swiss .pic { width: 100%; aspect-ratio: 16 / 9; background-image: url("/assets/endfield.webp"); background-size: cover; background-position: center; }

  /* ============ 03 ART DECO · Fate/Grand Order ============ */
  .deco { height: 540px; background: #0b1733; padding: 26px; }
  .deco .frame { position: absolute; inset: 18px; border: 1px solid #c9a24b; }
  .deco .frame::before, .deco .frame::after { content: ""; position: absolute; width: 22px; height: 22px; border: 1px solid #c9a24b; }
  .deco .frame::before { top: 8px; left: 8px; border-right: none; border-bottom: none; }
  .deco .frame::after { bottom: 8px; right: 8px; border-left: none; border-top: none; }
  .deco .sun { position: absolute; top: 34px; left: 50%; transform: translateX(-50%); }
  .deco .content { position: absolute; inset: 40px; display: flex; flex-direction: column; align-items: center; }
  .deco h3 { font-family: "Cinzel", serif; font-weight: 700; font-size: 34px; color: #f3e6c4; letter-spacing: 0.14em; margin-top: 40px; text-align: center; }
  .deco .divider { display: flex; align-items: center; gap: 10px; margin: 14px 0; color: #c9a24b; }
  .deco .divider i { width: 60px; height: 1px; background: #c9a24b; }
  .deco .caption { font-family: "Shippori Mincho", serif; font-size: 13px; color: #d9c79a; letter-spacing: 0.04em; line-height: 1.7; text-align: center; max-width: 460px; margin-bottom: 14px; }
  .deco .pic { flex: 1; width: 100%; margin-top: 6px; background-image: url("/assets/fgo.webp"); background-size: 100% auto; background-repeat: no-repeat; background-position: center 73%; border: 1px solid #c9a24b; box-shadow: 0 0 0 4px #0b1733, 0 0 0 5px rgba(201,162,75,.4); }

  /* ============ 04 PUNK · マーダーミステリー ============ */
  .punk { min-height: 380px; background: #0d0d0d;
    background-image: radial-gradient(rgba(255,255,255,.06) 1px, transparent 1px); background-size: 4px 4px; padding: 30px; }
  .punk .rn { display: flex; flex-wrap: wrap; gap: 4px; }
  .punk .rn span { font-weight: 900; font-size: 40px; line-height: 1; padding: 2px 8px; }
  .punk .rn .b { background: #fff; color: #000; font-family: "Archivo Black"; }
  .punk .rn .w { background: #000; color: #fff; border: 2px solid #fff; font-family: "Inter"; transform: rotate(-3deg); }
  .punk .rn .r { background: #e2231a; color: #000; font-family: "Archivo Black"; transform: rotate(2deg); }
  .punk .rn .i { background: #fff; color: #000; font-style: italic; font-family: "Inter"; }
  .punk .sub { font-family: var(--f-mono); font-size: 12px; color: #fff; margin-top: 22px; border-top: 3px double #fff; padding-top: 12px; letter-spacing: 0.04em; }
  .punk .stats { display: flex; gap: 8px; flex-wrap: wrap; }
  .punk .stats span { font-family: "Archivo Black"; font-size: 13px; background: #fff; color: #000; padding: 4px 10px; transform: rotate(-1deg); }
  .punk .stats span:nth-child(2) { background: #e2231a; transform: rotate(1.5deg); }
  .punk .statsrow { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 16px; flex-wrap: wrap; }
  .punk .fileshead { font-family: "Archivo Black"; font-size: 11px; color: #e2231a; letter-spacing: 0.1em; margin-top: 22px; border-top: 2px solid #fff; padding-top: 12px; }
  .punk .files { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
  .punk .files span { font-family: "JetBrains Mono"; font-size: 11px; background: #f2f2f2; color: #000; padding: 3px 8px; }
  .punk .files span:nth-child(3n) { transform: rotate(-1.5deg); }

  /* ============ 05 BAROQUE / VICTORIAN · クトゥルフ ============ */
  .vic { position: relative; min-height: 440px; background: #160a0e; color: #e8dcc0; padding: 40px; text-align: center; overflow: hidden;
    background-image: radial-gradient(circle at 50% 0%, rgba(122,90,46,.18), transparent 60%); }
  .vic .vframe { position: absolute; inset: 16px; border: 2px solid #7a5a2e; pointer-events: none; }
  .vic .vframe::before { content: ""; position: absolute; inset: 5px; border: 1px solid rgba(194,162,90,.45); }
  .vic .corner { position: absolute; color: #c2a25a; }
  .vic .corner.tl { top: 22px; left: 22px; }
  .vic .corner.tr { top: 22px; right: 22px; transform: scaleX(-1); }
  .vic .corner.bl { bottom: 22px; left: 22px; transform: scaleY(-1); }
  .vic .corner.br { bottom: 22px; right: 22px; transform: scale(-1,-1); }
  .vic .inner { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; padding: 14px 20px; }
  .vic .eyebrow { font-family: "Cinzel", serif; font-weight: 700; letter-spacing: 0.28em; font-size: 15px; color: #c2a25a; margin-top: 12px; }
  .vic .fleuron { color: #c2a25a; margin-top: 14px; }
  .vic .vjp { font-family: "Shippori Mincho", serif; font-weight: 700; font-size: 34px; color: #f2e6c7; margin-top: 12px; letter-spacing: 0.1em; }
  .vic .vdiv { display: flex; align-items: center; justify-content: center; gap: 14px; color: #c2a25a; margin: 20px 0; font-size: 13px; }
  .vic .vdiv i { width: 90px; height: 1px; background: #b7965280; }
  .vic .vlede { font-family: "Shippori Mincho", serif; font-size: 14px; line-height: 2.05; color: #cbba92; max-width: 480px; }
  .vic .vmeta { font-family: "Cinzel", serif; font-size: 12px; letter-spacing: 0.22em; color: #c2a25a; margin-top: 20px; }
  .vic .vlisthead { font-family: "Cinzel", serif; font-size: 11px; letter-spacing: 0.26em; color: #c2a25a; margin-top: 22px; }
  .vic .vlist { font-family: "Shippori Mincho", serif; font-size: 14px; color: #dccea2; line-height: 2.2; margin-top: 8px; max-width: 520px; }
  .vic .vlist .sep { color: #7a5a2e; margin: 0 8px; }

  /* ============ 06 MEMPHIS · エモクロア ============ */
  .memphis { min-height: 380px; background: #f4f1e8; padding: 32px; color: #1a1a1a; overflow: hidden; }
  .memphis .shapes { position: absolute; inset: 0; pointer-events: none; }
  .memphis h3 { font-family: "Poppins"; font-weight: 900; font-size: 44px; color: #1a1a1a; letter-spacing: -0.01em; position: relative; }
  .memphis h3 .hl-emo { color: #ff5c7a; }
  .memphis h3 .hl-klore { color: #1a1a1a; }
  .memphis h3 .hl-trpg { color: #00b3a4; }
  .memphis .en { font-family: "Poppins"; font-weight: 700; font-size: 13px; letter-spacing: 0.2em; color: #00b3a4; position: relative; }
  .memphis .lede { font-family: "Zen Kaku Gothic New"; font-size: 14px; color: #333; margin-top: 16px; max-width: 420px; position: relative; line-height: 1.7; }
  .memphis .chips { display: flex; gap: 10px; margin-top: 22px; flex-wrap: wrap; position: relative; }
  .memphis .chips span { font-family: "Poppins"; font-weight: 700; font-size: 13px; padding: 7px 14px; border: 2px solid #1a1a1a; }
  .memphis .chips span:nth-child(1) { background: #ffd23f; }
  .memphis .chips span:nth-child(2) { background: #4d9de0; color: #fff; }
  .memphis .shapes .sq { transform-box: fill-box; transform-origin: center; transform: rotate(20deg); }
  .memphis .mlisthead { font-family: "Poppins"; font-weight: 800; font-size: 12px; letter-spacing: 0.08em; color: #00b3a4; margin-top: 22px; position: relative; }
  .memphis .mlist { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; position: relative; }
  .memphis .mlist span { font-family: "Zen Kaku Gothic New"; font-weight: 700; font-size: 12px; padding: 5px 11px; border: 2px solid #1a1a1a; background: #fff; color: #1a1a1a; }

  /* ============ 07 BAUHAUS · その他アナログ ============ */
  .bau { min-height: 380px; background: #e8e4d8; display: grid; grid-template-columns: 300px 1fr; color: #111; }
  .bau .art { position: relative; background: #1a1a1a; overflow: hidden; }
  .bau .art .c1 { position: absolute; top: -40px; left: -40px; width: 200px; height: 200px; border-radius: 50%; background: #e2231a; }
  .bau .art .t1 { position: absolute; bottom: 0; left: 0; width: 0; height: 0; border-left: 150px solid transparent; border-right: 150px solid transparent; border-bottom: 190px solid #ffd23f; }
  .bau .art .s1 { position: absolute; top: 120px; right: -30px; width: 130px; height: 130px; background: #2b6cb0; transform: rotate(18deg); }
  .bau .r { padding: 32px 30px; display: flex; flex-direction: column; }
  .bau h3 { font-family: "Archivo Black"; font-size: 34px; line-height: 1; letter-spacing: -0.01em; }
  .bau .jp { font-family: "Zen Kaku Gothic New"; font-weight: 900; font-size: 24px; margin-top: 8px; }
  .bau .lede { font-family: "Zen Kaku Gothic New"; font-weight: 500; font-size: 15px; color: #333; margin-top: 14px; line-height: 1.7; }
  .bau .listhead { font-family: "Archivo Black"; font-size: 12px; letter-spacing: 0.06em; margin-top: auto; display: inline-flex; align-items: center; gap: 9px; }
  .bau .listhead::before { content: ""; width: 14px; height: 14px; background: #e2231a; }
  .bau .list { font-family: "Zen Kaku Gothic New"; font-weight: 700; font-size: 15px; color: #111; margin-top: 10px; line-height: 1.7; }

  /* ============ 08 RETRO · 外部リンク ============ */
  .retro { min-height: 360px; background: #2a1a12; padding: 34px; overflow: hidden; }
  .retro .stripes { position: absolute; top: 0; right: 0; width: 260px; height: 100%; }
  .retro .stripes i { position: absolute; right: -80px; top: -60px; width: 300px; height: 60px; border-radius: 30px; }
  .retro .en { font-family: "Righteous"; font-size: 13px; letter-spacing: 0.2em; color: #f4a259; position: relative; }
  .retro h3 { font-family: "Righteous"; font-size: 46px; color: #ffdd94; margin-top: 12px; position: relative; text-shadow: 3px 3px 0 #bc4b2b; }
  .retro .links { margin-top: 22px; display: flex; flex-direction: column; gap: 10px; position: relative; max-width: 460px; }
  .retro .links a { display: flex; align-items: center; justify-content: space-between; background: #f4ecd8; color: #2a1a12; border-radius: 999px; padding: 12px 22px; font-family: "Righteous"; font-size: 16px; transition: transform .18s; }
  .retro .links a:hover { transform: translateX(4px); }
  .retro .links a .tag { font-family: var(--f-mono); font-size: 11px; background: #f4a259; padding: 3px 10px; border-radius: 999px; }

  /* ============ 09 MODERNISM · Contact ============ */
  .mod { height: 300px; background: #f5f4f0; display: grid; grid-template-columns: 1.4fr 1fr; color: #111; font-family: "Inter"; }
  .mod .left { padding: 32px 34px; display: flex; flex-direction: column; justify-content: flex-end; border-right: 1px solid #111; }
  .mod h3 { font-weight: 900; font-size: 46px; letter-spacing: -0.03em; line-height: 1.0; }
  .mod .jp { font-family: "Zen Kaku Gothic New"; font-weight: 700; font-size: 16px; margin-top: 12px; color: #333; }
  .mod .right { display: flex; flex-direction: column; }
  .mod .chan { flex: 1; display: flex; align-items: center; justify-content: space-between; padding: 0 28px; border-bottom: 1px solid #111; font-weight: 700; font-size: 21px; letter-spacing: -0.01em; transition: padding .18s; }
  .mod .chan:last-child { border-bottom: none; }
  .mod .chan .ar { font-weight: 400; font-size: 20px; }
  .mod .chan.lead { font-size: 27px; font-weight: 900; }
  .mod .chan.rest { font-size: 18px; font-weight: 500; color: #333; }
  .mod .chan:hover { padding-left: 34px; }

  @media (max-width: 720px) {
    .suprem .s-pic { width: 480px; right: -120px; }
    .swiss h3 { font-size: 40px; }
    .bau { grid-template-columns: 1fr; }
    .bau .art { min-height: 160px; }
    .mod { grid-template-columns: 1fr; height: auto; }
    .mod .left { border-right: none; border-bottom: 1px solid #111; }
    .mod .chan { padding: 18px 28px; }
    .nav-links { display: none; }
  }
</style>
</head>
<body>

<header class="nav">
  <div class="nav-inner glass">
    <a class="brand" href="#top">
      <img class="brand-ava" src="/assets/icon.webp" alt="bidri" />
      <b>bidri</b><span class="dev">.dev</span>
    </a>
    <nav class="nav-links">
      <a href="#arknights">Games</a>
      <a href="#murder-mystery">TRPG</a>
      <a href="#links">Links</a>
    </nav>
    <a class="nav-cta" href="#contact">contact</a>
  </div>
</header>

<main class="stack" id="top">

  <!-- 01 アークナイツ · Suprematism -->
  <section class="sec" id="arknights" data-bg="#cdd2d8">
    <div class="card suprem">
      <div class="s s-red"></div>
      <div class="s s-yellow"></div>
      <div class="s s-bar"></div>
